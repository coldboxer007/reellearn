# Keep real keys in your shell or an ignored .env file. Never prefix this with VITE_.
OPENAI_API_KEY=

# Optional server-owned model overrides.
OPENAI_TEXT_MODEL=gpt-5.6-sol
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_AUDIO_MODEL=tts-1
REELLEARN_API_PORT=8787
# Cloud Run supplies PORT automatically; do not set it in source control.
