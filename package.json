{
  "name": "reellearn",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.18 <26"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c magenta,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "gcp-build": "npm run build",
    "lint": "oxlint",
    "preview": "vite preview",
    "start": "NODE_ENV=production tsx server/index.ts",
    "smoke:api": "tsx server/smoke.ts",
    "smoke:direction": "tsx server/direction-smoke.ts",
    "smoke:planning": "tsx server/planning-smoke.ts",
    "smoke:planning:live": "tsx server/live-planning-smoke.ts",
    "smoke:research-mode": "tsx server/research-mode-smoke.ts",
    "smoke:remotion": "tsx server/remotion-smoke.ts"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.495",
    "@remotion/media": "4.0.495",
    "@remotion/media-parser": "4.0.495",
    "@remotion/player": "4.0.495",
    "@remotion/renderer": "4.0.495",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "openai": "^6.48.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "remotion": "4.0.495",
    "tsx": "^4.23.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
